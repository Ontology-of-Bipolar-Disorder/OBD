    <!-- http://purl.obolibrary.org/obo/HP_0000739 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/HP_0000739">
        <rdfs:label>Anxiety</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/HP_5200230"/>
        <oboInOwl:id>HP:0000739</oboInOwl:id>
        <oboInOwl:hasExactSynonym>Anxiety</oboInOwl:hasExactSynonym>
        <oboInOwl:hasDbXref>SNOMEDCT_US:48694002</oboInOwl:hasDbXref>
        <oboInOwl:hasRelatedSynonym>Anxiety disease</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasDbXref>UMLS:C0003467</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>Excessive, persistent worry and fear</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>Anxiousness</oboInOwl:hasExactSynonym>
        <oboInOwl:hasDbXref>UMLS:C4020884</oboInOwl:hasDbXref>
        <obo:IAO_0000115>Intense feelings of nervousness, tension, or panic often arise in response to interpersonal stresses. There is worry about the negative effects of past unpleasant experiences and future negative possibilities. Individuals may feel fearful, apprehensive, or threatened by uncertainty, and they may also have fears of falling apart or losing control.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/hp.owl"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-8430-6039"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0692-412X"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-7405-0954"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-0072-5522"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-0224-647X"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-3398-7270"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0004-0873-4444"/>
    </owl:Class>
    


