    <!-- http://purl.obolibrary.org/obo/HP_0000716 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/HP_0000716">
        <rdfs:label>Depression</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/HP_0100851"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/HP_5200275"/>
        <oboInOwl:hasExactSynonym>Depressive episode</oboInOwl:hasExactSynonym>
        <oboInOwl:hasDbXref>SNOMEDCT_US:21061000119107</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>Depressivity</oboInOwl:hasExactSynonym>
        <oboInOwl:id>HP:0000716</oboInOwl:id>
        <oboInOwl:hasDbXref>UMLS:C0011581</oboInOwl:hasDbXref>
        <obo:IAO_0000115>Frequently experiencing feelings of being down, miserable, and/or hopeless; struggling to recover from these moods; having a pessimistic outlook on the future; feeling a pervasive sense of shame; having a low self-worth; experiencing thoughts of suicide and engaging in suicidal behavior.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>Depression</oboInOwl:hasExactSynonym>
        <oboInOwl:hasDbXref>SNOMEDCT_US:35489007</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>SNOMEDCT_US:78667006</oboInOwl:hasDbXref>
        <oboInOwl:hasRelatedSynonym>Depressive disorder</oboInOwl:hasRelatedSynonym>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/hp.owl"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1111-7357"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-7954-5235"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-2897-0458"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4298-5074"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-4618-6544"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/HP_0000718 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/HP_0000718">
