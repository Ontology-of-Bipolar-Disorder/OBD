    <!-- http://purl.obolibrary.org/obo/NCIT_C171128 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C171128">
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-Neoplastic Endocrine Pancreas Disorder</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C27067"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C53505"/>
        <obo:IAO_0000115 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A non-neoplastic disorder that affects the endocrine pancreas.</obo:IAO_0000115>
        <obo:NCIT_NHC0 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C171128</obo:NCIT_NHC0>
        <obo:NCIT_P208 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CL1405371</obo:NCIT_P208>
        <obo:NCIT_P106 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Disease or Syndrome</obo:NCIT_P106>
        <obo:NCIT_P108 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-Neoplastic Endocrine Pancreas Disorder</obo:NCIT_P108>
        <oboInOwl:hasExactSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-Neoplastic Endocrine Pancreas Disorder</oboInOwl:hasExactSynonym>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/ncit.owl"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C192882 -->

