    <!-- http://purl.obolibrary.org/obo/NCIT_C27550 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C27550">
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Non-Neoplastic Digestive System Disorder</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C2990"/>
