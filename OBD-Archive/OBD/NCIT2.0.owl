    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C34423">
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bipolar Disorder</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C92200"/>
        <obo:IAO_0000115 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A disorder of the brain that causes unusual shifts in mood, energy, activity levels and the ability to carry out day-to-day tasks. Often these moods range and shift from periods of elation and energized behavior to those of hopelessness and depression.</obo:IAO_0000115>
        <obo:NCIT_P108 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bipolar Disorder</obo:NCIT_P108>
        <oboInOwl:hasExactSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bipolar Disorder</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bipolar disorder, unspecified</oboInOwl:hasExactSynonym>
