        <obo:NCIT_P108 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancreatic Disorder</obo:NCIT_P108>
        <oboInOwl:hasExactSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancreatic Disorder</oboInOwl:hasExactSynonym>
        <obo:NCIT_P366 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pancreatic_Disorder</obo:NCIT_P366>
        <obo:NCIT_P375 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unspecified disease of pancreas</obo:NCIT_P375>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/ncit.owl"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C27067 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C27067">
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endocrine Pancreas Disorder</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C26842"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/NCIT_C27551"/>
        <obo:IAO_0000115 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A non-neoplastic or neoplastic disorder that affects the endocrine pancreatic tissue (islets of Langerhans). Representative examples include diabetes mellitus and neuroendocrine neoplasms.</obo:IAO_0000115>
