    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/DOID_0050735 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0050735">
        <rdfs:label xml:lang="en">X-linked monogenic disease</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/DOID_0050177"/>
