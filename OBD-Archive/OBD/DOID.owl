        <oboInOwl:hasDbXref>MIM:613751</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MIM:PS306955</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MIM:306955</oboInOwl:hasDbXref>
        <obo:IAO_0000115 xml:lang="en">A physical disorder characterized by the abnormal distribution of the major visceral organs within the chest and abdomen.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>MIM:614779</oboInOwl:hasDbXref>
