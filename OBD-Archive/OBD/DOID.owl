    <!-- http://purl.obolibrary.org/obo/DOID_0050736 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0050736">
        <rdfs:label xml:lang="en">autosomal dominant disease</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/DOID_0050739"/>
        <oboInOwl:created_by>lschriml</oboInOwl:created_by>
        <oboInOwl:creation_date>2012-07-24T12:51:47Z</oboInOwl:creation_date>
        <obo:IAO_0000115 xml:lang="en">An autosomal genetic disease that is characterized by the presence of one disease-associated mutation of a gene which is sufficient to cause the disease.</obo:IAO_0000115>
        <oboInOwl:id>DOID:0050736</oboInOwl:id>
        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
