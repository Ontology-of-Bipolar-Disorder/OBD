        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
        <obo:IAO_0000115 xml:lang="en">A chromosomal duplication syndrome that has_material_basis_in heterozygous interstitial duplication in chromosome 22q13 involving the SHANK3 gene.</obo:IAO_0000115>
        <oboInOwl:created_by>elvira</oboInOwl:created_by>
        <oboInOwl:hasDbXref>MIM:615538</oboInOwl:hasDbXref>
