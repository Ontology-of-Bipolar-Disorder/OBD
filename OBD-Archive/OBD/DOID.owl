    <!-- http://purl.obolibrary.org/obo/DOID_0050177 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0050177">
        <rdfs:label xml:lang="en">monogenic disease</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/DOID_630"/>
        <obo:IAO_0000115 xml:lang="en">A genetic disease that is the result of one or more abnormal alleles and may be dominant, semi-dominant, or recessive.</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>DOID:0050177</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.oboInOwllibrary.org/oboInOwl/doid#DO_AGR_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.oboInOwllibrary.org/oboInOwl/doid#DO_GXD_slim"/>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/doid.owl"/>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/DOID_0050545 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0050545">
