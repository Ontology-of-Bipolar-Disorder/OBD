        <oboInOwl:creation_date>2015-10-02T15:19:23Z</oboInOwl:creation_date>
        <obo:IAO_0000115 xml:lang="en">A chromosomal disease that has_material_basis_in extra copies of a chromosomal region.</obo:IAO_0000115>
        <oboInOwl:created_by>elvira</oboInOwl:created_by>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/doid.owl"/>
