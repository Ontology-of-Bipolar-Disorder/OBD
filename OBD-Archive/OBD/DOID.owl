    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0111723">
        <rdfs:label xml:lang="en">Jacobsen Syndrome</rdfs:label>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/DOID_0060388"/>
        <oboInOwl:hasDbXref>MESH:D054868</oboInOwl:hasDbXref>
